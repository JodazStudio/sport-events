# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# Cloudinary Configuration
NEXT_PUBLIC_CLOUDINARY_ACCOUNT_NAME=your-cloudinary-account-name

# Storage Configuration (MEGA S4 / AWS S3)
MEGA_S4_ENDPOINT=your-s3-endpoint
MEGA_S4_ACCESS_KEY=your-s3-access-key
MEGA_S4_SECRET_KEY=your-s3-secret-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Resend API Key
RESEND_API_KEY=re_123456789